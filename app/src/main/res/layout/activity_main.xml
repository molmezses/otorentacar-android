<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/navHostFragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:defaultNavHost="true"
            app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:navGraph="@navigation/nav_graph" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomBarContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_10dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_3xl"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:id="@+id/customBottomBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_10dp"
                android:paddingTop="@dimen/spacing_5dp"
                android:paddingBottom="@dimen/spacing_5dp"
                android:weightSum="5">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/bottom_nav_item_padding_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navHomeIndicator"
                        android:layout_width="@dimen/bottom_nav_indicator_width"
                        android:layout_height="@dimen/bottom_nav_indicator_height"
                        app:cardBackgroundColor="@color/bottom_nav_selected_bg"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavHome"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_home"
                            android:tint="@color/bottom_nav_active"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2xs"
                        android:fontFamily="@font/inter_medium"
                        android:text="Anasayfa"
                        android:textColor="@color/bottom_nav_active"
                        android:textSize="@dimen/text_xxs"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navReservations"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/bottom_nav_item_padding_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navReservationsIndicator"
                        android:layout_width="@dimen/bottom_nav_indicator_width"
                        android:layout_height="@dimen/bottom_nav_indicator_height"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavReservations"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_calendar"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavReservations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2xs"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_medium"
                        android:maxLines="1"
                        android:text="Rezervasyonlar"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="@dimen/text_xxs"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navFavorites"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/bottom_nav_item_padding_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navFavoritesIndicator"
                        android:layout_width="@dimen/bottom_nav_indicator_width"
                        android:layout_height="@dimen/bottom_nav_indicator_height"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavFavorites"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_favorite_fill"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavFavorites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2xs"
                        android:fontFamily="@font/inter_medium"
                        android:text="Favoriler"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="@dimen/text_xxs"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navBookings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/bottom_nav_item_padding_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navBookingsIndicator"
                        android:layout_width="@dimen/bottom_nav_indicator_width"
                        android:layout_height="@dimen/bottom_nav_indicator_height"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavBookings"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_search"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavBookings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2xs"
                        android:fontFamily="@font/inter_medium"
                        android:text="Sorgula"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="@dimen/text_xxs"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navContact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/bottom_nav_item_padding_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navContactIndicator"
                        android:layout_width="@dimen/bottom_nav_indicator_width"
                        android:layout_height="@dimen/bottom_nav_indicator_height"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavContact"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="@dimen/spacing_sm"
                            android:src="@drawable/ic_contact"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_2xs"
                        android:fontFamily="@font/inter_medium"
                        android:text="İletişim"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="@dimen/text_xxs"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/drawerMenu"
        layout="@layout/layout_drawer_menu"
        android:layout_width="@dimen/drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>