<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/navHostFragment"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:defaultNavHost="true"
            app:layout_constraintBottom_toTopOf="@id/bottomBarContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:navGraph="@navigation/nav_graph" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bottomBarContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/customBottomBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/navHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="3dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navHomeIndicator"
                        android:layout_width="72dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="@color/bottom_nav_selected_bg"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavHome"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_home"
                            android:tint="@color/bottom_nav_active"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="HOME"
                        android:textColor="@color/bottom_nav_active"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navBookings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="3dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navBookingsIndicator"
                        android:layout_width="72dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavBookings"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavBookings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="MY BOOKINGS"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/navContact"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="3dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/navContactIndicator"
                        android:layout_width="72dp"
                        android:layout_height="36dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <ImageView
                            android:id="@+id/ivNavContact"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="8dp"
                            android:src="@drawable/ic_contact"
                            android:tint="@color/bottom_nav_inactive"
                            tools:ignore="UseAppTint" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvNavContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="CONTACT"
                        android:textColor="@color/bottom_nav_inactive"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/inter_bold" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/drawerMenu"
        layout="@layout/layout_drawer_menu"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>