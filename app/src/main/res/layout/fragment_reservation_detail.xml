<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBack"
                android:layout_width="@dimen/card_height_sm"
                android:layout_height="@dimen/card_height_sm"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="@dimen/radius_14dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/radius_14dp"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="@color/text_primary"
                    tools:ignore="UseAppTint" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/radius_14dp"
                android:fontFamily="@font/inter_bold"
                android:text="Rezervasyon Detayı"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_2xl"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/cardBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/cardBack" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_3xl"
            android:fontFamily="@font/inter_bold"
            android:text="Rezervasyon Detayları"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_4xl"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:fontFamily="@font/inter_medium"
            android:lineSpacingExtra="@dimen/spacing_2xs"
            android:text="Bilgilerinizi doldurup rezervasyonu tamamlayabilirsiniz."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_md" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_22dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/tag_height_28dp"
                        app:cardBackgroundColor="@color/bg_input"
                        app:cardCornerRadius="@dimen/radius_14dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:fontFamily="@font/inter_bold"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:text="POPULAR"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_xs"
                            android:textStyle="bold" />

                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvVehicleName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="Araç Adı"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVehicleInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:fontFamily="@font/inter_bold"
                        android:text="Özellik 1 | Özellik 2"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/vehicle_image_width_150dp"
                    android:layout_height="@dimen/vehicle_image_height_100dp"
                    android:layout_marginStart="@dimen/spacing_5dp"
                    app:cardBackgroundColor="@color/bg_input"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/ivVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_directions_car" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="@dimen/radius_22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="ALIŞ"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPickupDateTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:fontFamily="@font/inter_medium"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="Gün Ay Yıl, 00:00"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="@dimen/radius_14dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="@dimen/radius_22dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="DÖNÜŞ"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDropOffDateTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:fontFamily="@font/inter_medium"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="Gün Ay Yıl, 00:00"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/drawer_menu_icon_size"
                android:layout_height="@dimen/drawer_menu_icon_size"
                android:src="@drawable/ic_person"
                android:tint="@color/primary_green_dark"
                tools:ignore="UseAppTint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_10dp"
                android:fontFamily="@font/inter_bold"
                android:text="Kişisel Bilgiler"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="AD SOYAD"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_10dp"
                    app:boxBackgroundColor="@color/bg_input"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                    app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                    app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                    app:boxCornerRadiusTopStart="@dimen/radius_lg"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:hint=""
                        android:inputType="textPersonName"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_light"
                        android:textSize="@dimen/text_md"
                        app:errorTextAppearance="@style/TextInputErrorStyle"
                        app:errorTextColor="@color/error_red" />

                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="TELEFON"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_10dp"
                            app:boxBackgroundColor="@color/bg_input"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                            app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                            app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                            app:boxCornerRadiusTopStart="@dimen/radius_lg"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_regular"
                                android:hint=""
                                android:inputType="phone"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_light"
                                android:textSize="@dimen/text_md"
                                app:errorTextAppearance="@style/TextInputErrorStyle"
                                app:errorTextColor="@color/error_red" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <Space
                        android:layout_width="@dimen/radius_14dp"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="DOĞUM TARİHİ"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBirthDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_10dp"
                            app:boxBackgroundColor="@color/bg_input"
                            app:boxBackgroundMode="filled"
                            app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                            app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                            app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                            app:boxCornerRadiusTopStart="@dimen/radius_lg"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBirthDate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="true"
                                android:focusable="false"
                                android:fontFamily="@font/inter_regular"
                                android:hint=""
                                android:inputType="none"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_light"
                                android:textSize="@dimen/text_md"
                                app:errorTextAppearance="@style/TextInputErrorStyle"
                                app:errorTextColor="@color/error_red" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="@font/inter_bold"
                    android:text="E-POSTA"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_10dp"
                    app:boxBackgroundColor="@color/bg_input"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                    app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                    app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                    app:boxCornerRadiusTopStart="@dimen/radius_lg"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:hint=""
                        android:inputType="textEmailAddress"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_light"
                        android:textSize="@dimen/text_md"
                        app:errorTextAppearance="@style/TextInputErrorStyle"
                        app:errorTextColor="@color/error_red" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="@font/inter_bold"
                    android:text="UÇUŞ KODU (OPSIYONEL)"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFlightCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_10dp"
                    app:boxBackgroundColor="@color/bg_input"
                    app:boxBackgroundMode="filled"
                    app:boxCornerRadiusBottomEnd="@dimen/radius_lg"
                    app:boxCornerRadiusBottomStart="@dimen/radius_lg"
                    app:boxCornerRadiusTopEnd="@dimen/radius_lg"
                    app:boxCornerRadiusTopStart="@dimen/radius_lg"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFlightCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_regular"
                        android:hint=""
                        android:inputType="text"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_light"
                        android:textSize="@dimen/text_md"
                        app:errorTextColor="@color/error_red" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_22dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/drawer_menu_icon_size"
                        android:layout_height="@dimen/drawer_menu_icon_size"
                        android:src="@drawable/ic_credit_card"
                        android:tint="@color/primary_green_dark"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="Ödeme Özeti"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_2xl"
                        android:textStyle="bold" />

                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Araç Kiralama Bedeli"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_md"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvRentalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="€0"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/radius_14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:text="Ek Hizmetler"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_md"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvExtraPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="€0"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/spacing_3xs"
                    android:layout_marginTop="@dimen/spacing_18dp"
                    android:background="@color/bg_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="@font/inter_bold"
                    android:text="GENEL TOPLAM"
                    android:textColor="@color/primary_green_dark"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_5dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="€0"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_3xl"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelectedExtras"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_22dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="Ek Hizmetler"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutSelectedExtrasContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_18dp"
                    android:orientation="vertical" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteReservation"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_70dp"
            android:layout_marginTop="@dimen/spacing_22dp"
            android:fontFamily="@font/inter_bold"
            android:text="Rezervasyonu Tamamla"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_green_dark"
            app:cornerRadius="@dimen/radius_lg" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>