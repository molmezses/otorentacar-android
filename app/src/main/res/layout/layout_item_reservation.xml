<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_lg"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="@dimen/radius_xl"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layoutHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/layoutActions"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvReservationCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="Kod"
                    android:textColor="@color/primary_green_dark"
                    android:textSize="@dimen/text_xl"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvVehicleName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2xs"
                    android:fontFamily="@font/inter_bold"
                    android:text="Araç Adı"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/primary_green_light"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:paddingVertical="@dimen/spacing_xs"
                        android:text="Yeni"
                        android:textColor="@color/primary_green_dark"
                        android:textSize="@dimen/text_sm"
                        android:textStyle="bold" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDelete"
                    android:layout_width="@dimen/reservation_delete_button_size"
                    android:layout_height="@dimen/reservation_delete_button_size"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/bg_input"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/ivDelete"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/reservation_delete_icon_padding"
                        android:src="@drawable/ic_delete"
                        android:tint="@android:color/holo_red_light"
                        tools:ignore="UseAppTint" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvPickupLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:fontFamily="@font/inter_medium"
            android:text="Alış: "
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_sm" />

        <TextView
            android:id="@+id/tvDropOffLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fontFamily="@font/inter_medium"
            android:text="Dönüş:"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_sm" />

        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fontFamily="@font/inter_medium"
            android:text="24 Nis 2026, 13:26 - 30 Nis 2026, 13:26"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_sm" />

        <TextView
            android:id="@+id/tvTotalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:fontFamily="@font/inter_bold"
            android:text="€0"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_60dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:fontFamily="@font/inter_bold"
            android:text="Detayı Gör"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            app:backgroundTint="@color/primary_green_dark"
            app:cornerRadius="@dimen/radius_lg" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>