<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <include
            android:id="@+id/topBar"
            layout="@layout/layout_top_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_3xl"
            android:fontFamily="@font/inter_bold"
            android:text="Hizmetlerimiz"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_4xl"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:fontFamily="@font/inter_medium"
            android:text="Otorentacar ile sunduğumuz avantajlar"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_md" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_22dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:lineSpacingExtra="@dimen/spacing_2xs"
                    android:text="@string/services_intro_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_2xl"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:fontFamily="@font/inter_regular"
                    android:lineSpacingExtra="@dimen/spacing_2xs"
                    android:text="@string/services_intro_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSupport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_22dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/card_size_62dp"
                    android:layout_height="@dimen/card_size_62dp"
                    app:cardBackgroundColor="@color/primary_green_dark"
                    app:cardCornerRadius="@dimen/radius_20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/spacing_18dp"
                        android:src="@drawable/ic_call"
                        android:tint="@color/white"
                        tools:ignore="UseAppTint" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_support_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_support_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDelivery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/card_size_62dp"
                    android:layout_height="@dimen/card_size_62dp"
                    app:cardBackgroundColor="@color/primary_green_dark"
                    app:cardCornerRadius="@dimen/radius_20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/spacing_18dp"
                        android:src="@drawable/ic_key"
                        android:tint="@color/white"
                        tools:ignore="UseAppTint" />

                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_delivery_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_delivery_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCleanCars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/card_size_62dp"
                    android:layout_height="@dimen/card_size_62dp"
                    app:cardBackgroundColor="@color/primary_green_dark"
                    app:cardCornerRadius="@dimen/radius_20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/spacing_18dp"
                        android:src="@drawable/ic_eco"
                        android:tint="@color/white"
                        tools:ignore="UseAppTint" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_clean_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_clean_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLuxury"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/card_size_62dp"
                    android:layout_height="@dimen/card_size_62dp"
                    app:cardBackgroundColor="@color/primary_green_dark"
                    app:cardCornerRadius="@dimen/radius_20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/spacing_18dp"
                        android:src="@drawable/ic_directions_car"
                        android:tint="@color/white"
                        tools:ignore="UseAppTint" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_luxury_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_luxury_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="@dimen/radius_26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/card_size_62dp"
                    android:layout_height="@dimen/card_size_62dp"
                    app:cardBackgroundColor="@color/primary_green_dark"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/spacing_18dp"
                        android:src="@drawable/ic_stacks"
                        android:tint="@color/white"
                        tools:ignore="UseAppTint" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_lg"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_options_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_10dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="@dimen/spacing_2xs"
                        android:text="@string/services_options_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_sm" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>