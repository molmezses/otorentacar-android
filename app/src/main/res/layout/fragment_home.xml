<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xxl">

        <include
            android:id="@+id/topBar"
            layout="@layout/layout_top_bar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_3xl"
            android:fontFamily="@font/inter_bold"
            android:text="Mükemmel Sürüşünüzü"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_4xl"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter_bold"
            android:text="Bugün Keşfedin."
            android:textColor="@color/primary_green_dark"
            android:textSize="@dimen/text_4xl"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_app_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="PICK-UP LOCATION"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_location_card_height"
                android:layout_marginTop="@dimen/spacing_10dp"
                app:cardBackgroundColor="@color/bg_input"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_near_me"
                        android:tint="@color/primary_green_dark"
                        tools:ignore="UseAppTint" />

                    <AutoCompleteTextView
                        android:id="@+id/actPickupLocation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="@dimen/radius_14dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:completionThreshold="1"
                        android:dropDownAnchor="@id/actPickupLocation"
                        android:dropDownHeight="wrap_content"
                        android:dropDownVerticalOffset="@dimen/spacing_sm"
                        android:ellipsize="end"
                        android:fontFamily="@font/inter_medium"
                        android:hint="Şehir veya Havalimanı"
                        android:inputType="none"
                        android:maxLines="2"
                        android:paddingVertical="0dp"
                        android:scrollHorizontally="false"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/text_md" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    android:id="@+id/tvDropInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_medium"
                    android:text="Farklı bir yerde bırak"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_md"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Switch
                    android:id="@+id/switchDrop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/switch_thumb_selector"
                    android:trackTint="@color/switch_track_selector"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/layoutDropOffSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_10dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="DROP-OFF LOCATION"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/home_location_card_height"
                    android:layout_marginTop="@dimen/spacing_10dp"
                    app:cardBackgroundColor="@color/bg_input"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_lg">

                        <ImageView
                            android:layout_width="@dimen/icon_md"
                            android:layout_height="@dimen/icon_md"
                            android:src="@drawable/ic_near_me"
                            android:tint="@color/primary_green_dark"
                            tools:ignore="UseAppTint" />

                        <AutoCompleteTextView
                            android:id="@+id/actDropOffLocation"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="@dimen/radius_14dp"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:completionThreshold="1"
                            android:dropDownAnchor="@id/actDropOffLocation"
                            android:dropDownHeight="wrap_content"
                            android:dropDownVerticalOffset="@dimen/spacing_sm"
                            android:ellipsize="end"
                            android:fontFamily="@font/inter_medium"
                            android:hint="Dönüş Lokasyonu"
                            android:inputType="none"
                            android:maxLines="2"
                            android:paddingVertical="0dp"
                            android:scrollHorizontally="false"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_md" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="PICK-UP DATE"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/home_date_time_card_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        app:cardBackgroundColor="@color/bg_input"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="@dimen/radius_14dp"
                            android:paddingTop="@dimen/spacing_5dp"
                            android:paddingEnd="@dimen/radius_14dp"
                            android:paddingBottom="@dimen/spacing_5dp">

                            <TextView
                                android:id="@+id/tvPickupDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:lineSpacingExtra="@dimen/spacing_3xs"
                                android:text="09 Nis\n2026"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/ivPickupDate"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivPickupDate"
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_calendar"
                                android:tint="@color/primary_green_dark"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:ignore="UseAppTint" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <Space
                    android:layout_width="@dimen/radius_14dp"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="PICK-UP TIME"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/home_date_time_card_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        app:cardBackgroundColor="@color/bg_input"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="@dimen/radius_14dp"
                            android:paddingTop="@dimen/spacing_md"
                            android:paddingEnd="@dimen/radius_14dp"
                            android:paddingBottom="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvPickupTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:text="10:00"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/ivPickupTime"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivPickupTime"
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_time"
                                android:tint="@color/primary_green_dark"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:ignore="UseAppTint" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="DROP-OFF DATE"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/home_date_time_card_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        app:cardBackgroundColor="@color/bg_input"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="@dimen/radius_14dp"
                            android:paddingTop="@dimen/spacing_md"
                            android:paddingEnd="@dimen/radius_14dp"
                            android:paddingBottom="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvDropOffDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:lineSpacingExtra="@dimen/spacing_3xs"
                                android:text="12 Nis\n2026"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/ivDropOffDate"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivDropOffDate"
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_calendar"
                                android:tint="@color/primary_green_dark"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:ignore="UseAppTint" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <Space
                    android:layout_width="@dimen/radius_14dp"
                    android:layout_height="wrap_content" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="DROP-OFF TIME"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_sm" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/home_date_time_card_height"
                        android:layout_marginTop="@dimen/spacing_sm"
                        app:cardBackgroundColor="@color/bg_input"
                        app:cardCornerRadius="@dimen/radius_lg"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="@dimen/radius_14dp"
                            android:paddingTop="@dimen/spacing_md"
                            android:paddingEnd="@dimen/radius_14dp"
                            android:paddingBottom="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tvDropOffTime"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_bold"
                                android:text="10:00"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_md"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@+id/ivDropOffTime"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivDropOffTime"
                                android:layout_width="@dimen/icon_md"
                                android:layout_height="@dimen/icon_md"
                                android:src="@drawable/ic_time"
                                android:tint="@color/primary_green_dark"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                tools:ignore="UseAppTint" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvDateValidationError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:fontFamily="@font/inter_bold"
                android:text="Dönüş tarihi, alış tarihinden sonra olmalıdır."
                android:textColor="@android:color/holo_red_dark"
                android:textSize="@dimen/text_sm"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindCar"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_70dp"
                android:layout_marginTop="@dimen/spacing_18dp"
                android:fontFamily="@font/inter_bold"
                android:text="Araç Bul"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:backgroundTint="@color/primary_green_dark"
                app:cornerRadius="@dimen/radius_lg" />

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_3xl">

            <TextView
                android:id="@+id/tvFeaturedTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_md"
                android:fontFamily="@font/inter_bold"
                android:text="Öne Çıkan Kiralık Araçlar"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvSeeAll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvSeeAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:fontFamily="@font/inter_bold"
                android:text="Tümünü Gör"
                android:textColor="@color/primary_green_dark"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/tvFeaturedTitle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvFeaturedTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFeaturedVehicles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_18dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>